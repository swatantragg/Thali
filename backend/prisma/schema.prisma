generator client {
  provider      = "prisma-client-js"
  // "native" → local dev; musl/openssl-3 → node:20-alpine (Docker) runtime
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Sex {
  male
  female
}

enum Goal {
  cut
  maintain
  bulk
}

enum Meal {
  Breakfast
  Lunch
  Dinner
  Snack
}

// ─── Models ───────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")          // null for Google-only accounts
  googleSub    String?  @unique @map("google_sub")      // Google subject id, null for password accounts
  name         String?
  // Bumped to invalidate every outstanding JWT for this user (logout-everywhere,
  // credential compromise). Each token embeds the value it was signed with.
  tokenVersion Int      @default(0) @map("token_version")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile           Profile?
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model PushSubscription {
  // One row per device/browser the user has enabled notifications on.
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique               // push service URL — identifies the sub
  p256dh    String                          // client public key (payload encryption)
  auth      String                          // client auth secret
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Profile {
  // id == User.id (1:1) — set during onboarding, not auto-generated
  id            String   @id @db.Uuid
  user          User     @relation(fields: [id], references: [id], onDelete: Cascade)
  name          String?
  sex           Sex      @default(male)
  age           Int
  heightCm      Decimal  @map("height_cm")      @db.Decimal(5, 1)
  weightKg      Decimal  @map("weight_kg")      @db.Decimal(5, 2)
  activityLevel Decimal  @default(1.55) @map("activity_level") @db.Decimal(4, 3)
  goal          Goal     @default(maintain)
  calTarget     Int      @map("cal_target")
  proteinTarget Int      @map("protein_target")
  carbTarget    Int      @map("carb_target")
  fatTarget     Int      @map("fat_target")
  fibreTarget   Int      @default(30) @map("fibre_target")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  foodLogs   FoodLog[]
  weightLogs WeightLog[]
  fastLogs   FastLog[]

  @@map("profiles")
}

model Food {
  id              BigInt  @id @default(autoincrement())
  name            String
  caloriesPer100g Decimal @map("calories_per_100g") @db.Decimal(7, 2)
  protein         Decimal @db.Decimal(6, 2)
  carbs           Decimal @db.Decimal(6, 2)
  fat             Decimal @db.Decimal(6, 2)
  fibre           Decimal @db.Decimal(6, 2)
  source          String  @default("INDB")   // "usda" | "openfoodfacts" | "custom" | …

  foodLogs FoodLog[]

  @@unique([name, source])
  @@map("foods")
}

model FoodLog {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id")   @db.Uuid
  foodId    BigInt   @map("food_id")
  logDate   DateTime @default(dbgenerated("CURRENT_DATE")) @map("log_date") @db.Date
  meal      Meal
  quantityG Decimal  @map("quantity_g") @db.Decimal(7, 2)
  calories  Decimal  @db.Decimal(7, 2)
  protein   Decimal  @db.Decimal(6, 2)
  carbs     Decimal  @db.Decimal(6, 2)
  fat       Decimal  @db.Decimal(6, 2)
  fibre     Decimal  @db.Decimal(6, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile Profile @relation(fields: [userId],  references: [id], onDelete: Cascade)
  food    Food    @relation(fields: [foodId],  references: [id], onDelete: Restrict)

  @@map("food_logs")
}

model FastLog {
  // A meal the user deliberately skipped (fasting) — counts as "covered" for
  // consistency so a planned skip doesn't break the streak.
  id      BigInt   @id @default(autoincrement())
  userId  String   @map("user_id") @db.Uuid
  logDate DateTime @map("log_date") @db.Date
  meal    Meal

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate, meal])
  @@map("fast_logs")
}

model WeightLog {
  id       BigInt   @id @default(autoincrement())
  userId   String   @map("user_id") @db.Uuid
  logDate  DateTime @default(dbgenerated("CURRENT_DATE")) @map("log_date") @db.Date
  weightKg Decimal  @map("weight_kg") @db.Decimal(5, 2)

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, logDate])
  @@map("weight_logs")
}
